# Copy this file to .env and fill in real values.
# The .env file is git-ignored and must never be committed.

# --- ElevenLabs Conversational AI ---
# API key from https://elevenlabs.io (Profile -> API Keys)
ELEVENLABS_API_KEY=
# Agent ID of the published Conversational AI agent (Agents dashboard)
ELEVENLABS_AGENT_ID=

# --- Anam ---
# API key from https://lab.anam.ai
ANAM_API_KEY=
# Persona ID of the character configured in Anam Lab. Anam Lab exposes a
# Persona ID for both custom and stock characters; the app uses it to start
# a stateful persona session.
ANAM_PERSONA_ID=your_anam_persona_id_here
# Optional legacy fallback: only used if ANAM_PERSONA_ID is empty, to build an
# ephemeral session from a raw avatar ID instead.
# ANAM_AVATAR_ID=
# Optional: Anam voice ID (only used in the avatarId fallback mode)
ANAM_VOICE_ID=

# --- Server ---
PORT=5180
